# --- Database ---
DATABASE_URL="postgresql://languagerooms:languagerooms_dev@localhost:5432/languagerooms"

# --- Sessions ---
# 32+ byte random secret for signing session JWTs (openssl rand -hex 32)
SESSION_SECRET="change_me_to_a_random_64_char_hex_string_change_me_change_me!!"

# --- LiveKit SFU ---
# Must match the `keys:` entry in livekit.yaml
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="devsecret_languagerooms_local_only_0123456789abcdef"
# Server-side API endpoint (HTTP)
LIVEKIT_HOST="http://localhost:7880"
# Browser-facing WebSocket URL (wss:// in production)
NEXT_PUBLIC_LIVEKIT_URL="ws://localhost:7880"

# --- Moderation ---
# Provider for automated frame scanning: "stub" in dev (see docs/abuse-handling.md)
CONTENT_MODERATION_PROVIDER="stub"
# Where captured report evidence frames are stored in dev (S3 or similar in prod)
EVIDENCE_STORAGE_DIR="./evidence"

# --- App ---
NODE_ENV="development"
APP_BASE_URL="http://localhost:3000"
LOG_LEVEL="info"
