// LanguageRooms data model.
// Models are introduced milestone by milestone; see CHANGELOG.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & auth (M2) ──────────────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR // platform moderator: moderation queue access
  ADMIN     // full admin: bans, takedowns, role management
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  displayName      String
  role             UserRole  @default(USER)
  // Explicit consent to the video conduct rules; required before the user
  // may join any room. Timestamped, not a boolean, for auditability.
  conductConsentAt DateTime?
  status           UserStatus @default(ACTIVE)
  bannedUntil      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  ageVerification AgeVerification?
  languages       LanguageProfile[]
  roomsCreated    Room[]            @relation("RoomCreator")
  participations  RoomParticipant[]
  notes           RoomNote[]
  ratings         RoomRating[]
  reportsFiled    Report[]          @relation("ReportsFiled")
  reportsReceived Report[]          @relation("ReportsReceived")
  blocksMade      Block[]           @relation("BlocksMade")
  blocksReceived  Block[]           @relation("BlocksReceived")
  strikes         Strike[]
  warnings        UserWarning[]
  whiteboardItems WhiteboardItem[]
}

// ─── Language profile & onboarding (M3) ─────────────────────────────────────

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum LanguageKind {
  NATIVE
  TARGET
}

model LanguageProfile {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  languageCode String // ISO 639-1
  kind         LanguageKind
  level        CefrLevel? // required for TARGET, null for NATIVE

  @@unique([userId, languageCode, kind])
  @@index([userId])
}

// ─── Rooms & directory (M3) ─────────────────────────────────────────────────

model Room {
  id           String     @id @default(cuid())
  name         String
  topic        String?
  languageCode String
  level        CefrLevel? // null = all levels welcome
  isVoiceOnly  Boolean    @default(false)
  capacity     Int        @default(12)
  isLocked     Boolean    @default(false)
  isModerated  Boolean    @default(false) // raise-hand-to-speak mode (M5)
  isTakenDown  Boolean    @default(false) // admin takedown (M6)
  createdById  String
  createdBy    User       @relation("RoomCreator", fields: [createdById], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  participants RoomParticipant[]
  notes        RoomNote[]
  ratings      RoomRating[]
  whiteboard   WhiteboardItem[]

  @@index([languageCode, level])
}

enum RoomRole {
  HOST
  MODERATOR
  PARTICIPANT
}

/// One row per user per room; `leftAt` null means currently present.
/// Kept in sync with the SFU via LiveKit webhooks (M4).
model RoomParticipant {
  id       String    @id @default(cuid())
  roomId   String
  room     Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     RoomRole  @default(PARTICIPANT)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  // Set when kicked by a host/moderator; blocks rejoin until it passes (M5).
  kickedUntil DateTime?

  @@unique([roomId, userId])
  @@index([roomId, leftAt])
}

// ─── Age gating (M2) — see docs/age-gating.md ───────────────────────────────

enum AgeVerificationResult {
  PASSED
  FAILED
}

/// The stored *result* of age verification at registration (18+ hard floor).
/// A row exists only for accounts that PASSED — under-18 signups never
/// become users; their attempts are recorded in AgeGateAttempt.
model AgeVerification {
  id                String                @id @default(cuid())
  userId            String                @unique
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth       DateTime              @db.Date
  ageAtVerification Int
  result            AgeVerificationResult
  method            String                @default("dob-self-attestation")
  verifiedAt        DateTime              @default(now())
}

/// Every signup age-gate evaluation, pass or fail, keyed by hashed email and
/// IP. Used to lock out retries after a rejected date of birth so users
/// cannot simply edit their DOB and resubmit.
model AgeGateAttempt {
  id        String                @id @default(cuid())
  emailHash String
  ipAddress String
  result    AgeVerificationResult
  createdAt DateTime              @default(now())

  @@index([emailHash, createdAt])
  @@index([ipAddress, createdAt])
}

// ─── Rate limiting (M2) ─────────────────────────────────────────────────────

/// Fixed-window rate-limit counters, Postgres-backed (see lib/rate-limit.ts).
model RateLimitCounter {
  key         String   @id
  windowStart DateTime
  count       Int      @default(0)
}

// ─── Host controls, support panel, ratings (M5) ─────────────────────────────

/// Immutable audit trail of every moderation-relevant action, including
/// in-room host actions (mute/kick/lock/promote) and admin actions (M6).
model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  action       String
  roomId       String?
  targetUserId String?
  detail       Json?
  createdAt    DateTime @default(now())

  @@index([roomId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([actorId, createdAt])
}

enum NoteKind {
  CORRECTION
  VOCAB
  LINK
  NOTE
}

/// Support-panel entries (corrections, vocabulary, links) — the secondary
/// text channel. Persisted so late joiners see recent notes.
model RoomNote {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  kind      NoteKind @default(NOTE)
  text      String
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}

/// Post-session room rating collected on leave.
model RoomRating {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1..5, validated at the API layer
  feedback  String?
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}

// ─── Abuse handling (M6) — see docs/abuse-handling.md ───────────────────────

enum UserStatus {
  ACTIVE
  TEMP_BANNED
  PERM_BANNED
}

enum ReportReason {
  NUDITY_SEXUAL
  HARASSMENT
  HATE_SPEECH
  VIOLENCE_SELF_HARM
  SUSPECTED_UNDERAGE
  CHILD_SAFETY // CSAM-class: always SEVERE, always escalated
  SPAM
  OTHER
}

enum ReportSeverity {
  NORMAL
  SEVERE
}

enum ReportStatus {
  PENDING
  RESOLVED_ACTIONED
  RESOLVED_DISMISSED
  ESCALATED
}

model Report {
  id           String         @id @default(cuid())
  /// null = generated by the automated content-moderation pipeline
  reporterId   String?
  reporter     User?          @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: SetNull)
  targetUserId String
  targetUser   User           @relation("ReportsReceived", fields: [targetUserId], references: [id], onDelete: Cascade)
  roomId       String?
  reason       ReportReason
  severity     ReportSeverity @default(NORMAL)
  comment      String?
  status       ReportStatus   @default(PENDING)
  source       String         @default("user") // "user" | "automated"
  createdAt    DateTime       @default(now())
  resolvedAt   DateTime?
  resolvedById String?
  resolution   String?

  evidenceFrames EvidenceFrame[]

  @@index([status, createdAt])
  @@index([targetUserId, createdAt])
  @@index([roomId, createdAt])
}

/// Captured frame(s) of the reported participant's stream. Stored on the
/// evidence volume (S3 or equivalent in production), never inline in the DB.
/// Evidence for SEVERE reports is preservation-locked (docs/abuse-handling.md).
model EvidenceFrame {
  id          String   @id @default(cuid())
  reportId    String
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  storagePath String
  contentType String
  sha256      String
  capturedAt  DateTime @default(now())
}

/// A blocked B: they are never admitted to the same room again (either
/// direction) and B's streams are hidden from A.
model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

/// Strikes drive escalating automatic penalties (see strikePenalty).
model Strike {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason     String
  reportId   String?
  issuedById String? // null = automated
  createdAt  DateTime  @default(now())
  expiresAt  DateTime? // expired strikes don't count toward penalties

  @@index([userId, createdAt])
}

model UserWarning {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  message        String
  issuedById     String?
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?

  @@index([userId])
}

// ─── Collaborative whiteboard (feature/ui-whiteboard) ───────────────────────

enum WhiteboardItemKind {
  STROKE
  IMAGE
}

/// One element on a room's shared whiteboard. Strokes carry their points in
/// `data`; images carry placement plus a server-side storagePath (uploads are
/// scanned by the content-moderation provider before they appear).
model WhiteboardItem {
  id        String             @id @default(cuid())
  roomId    String
  room      Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  authorId  String
  author    User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  kind      WhiteboardItemKind
  data      Json
  createdAt DateTime           @default(now())

  @@index([roomId, createdAt])
}
